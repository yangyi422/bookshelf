APP_ENV=production
APP_PORT=8080
DATA_DIR=/app/data
# Production Compose only. Development always uses a Docker named volume.
BOOKSHELF_DATA_DIR=/opt/bookshelf/data
GOPROXY=https://goproxy.cn,direct
PUBLIC_BASE_URL=https://books.example.com
TZ=Asia/Shanghai

ADMIN_USERNAME=
ADMIN_PASSWORD=

# Optional advanced override. Leave empty to generate and persist it under DATA_DIR/config.
SESSION_SECRET=
# auto (recommended), always, or never
SESSION_COOKIE_SECURE=auto
SESSION_TTL_HOURS=168

OPDS_ENABLED=true
OPDS_ALLOW_INSECURE_HTTP=false
OPDS_ACCESS_MODE=https_only
OPDS_USERNAME=reader
OPDS_PASSWORD=

# Advanced: direct peers whose X-Forwarded-* headers are trusted.
TRUSTED_PROXIES=172.16.0.0/12

MAX_UPLOAD_SIZE_MB=500
SQLITE_BUSY_TIMEOUT_MS=5000
BACKUP_RETENTION_DAYS=30
LOG_LEVEL=info
