APP_ENV=production
APP_PORT=8080
DATA_DIR=/app/data
# Optional host override used only by Docker Compose:
# DATA_HOST_PATH=/opt/bookshelf/data
PUBLIC_BASE_URL=https://books.example.com
TZ=Asia/Shanghai

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-immediately

SESSION_SECRET=replace-with-a-long-random-string-at-least-32-characters
SESSION_TTL_HOURS=168

OPDS_ENABLED=true
OPDS_USERNAME=reader
OPDS_PASSWORD=replace-with-a-strong-password

MAX_UPLOAD_SIZE_MB=500
SQLITE_BUSY_TIMEOUT_MS=5000
BACKUP_RETENTION_DAYS=30
LOG_LEVEL=info
